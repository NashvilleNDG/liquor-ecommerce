# ── NDG Platform Credentials ────────────────────────────────────────────────
# These are held at the NDG platform level and shared across all store deployments.
# Never commit .env.local — it is gitignored.

# DoorDash Drive (Platform/ISV account)
# Get from: https://developer.doordash.com/portal/integration
DOORDASH_DEVELOPER_ID=your_developer_id_here
DOORDASH_KEY_ID=your_key_id_here
DOORDASH_SIGNING_SECRET=your_signing_secret_here

# Uber Direct (Platform account)
# Get from: https://developer.uber.com/dashboard
UBER_CLIENT_ID=your_client_id_here
UBER_CLIENT_SECRET=your_client_secret_here
